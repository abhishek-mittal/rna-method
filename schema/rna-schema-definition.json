{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/abhishekmittal/rna-method/schema/rna-schema-definition.json",
  "title": "RNA Method Schema",
  "description": "JSON Schema validator for rna-schema.json files. Version 1.2.",
  "type": "object",
  "required": ["meta", "agents", "rules", "skills", "hooks", "joiningPatterns"],
  "additionalProperties": false,
  "properties": {
    "$schema":    { "type": "string" },
    "$id":        { "type": "string" },
    "title":      { "type": "string" },
    "description":{ "type": "string" },
    "version":    { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "rnaVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "outputFormat": {
      "type": "string",
      "enum": ["verbose", "toon", "structured"],
      "default": "verbose"
    },
    "resilience": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled":       { "type": "boolean" },
        "maxRetries":    { "type": "integer", "minimum": 0, "maximum": 10 },
        "failureLogDir": { "type": "string" }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "onSessionStart": { "type": "array", "items": { "type": "string" } },
        "onToolComplete": { "type": "array", "items": { "type": "string" } },
        "onSessionEnd":   { "type": "array", "items": { "type": "string" } }
      }
    },
    "registry": { "type": "string" },
    "meta": {
      "type": "object",
      "required": ["projectName", "platform", "schemaVersion", "lastUpdated", "director"],
      "additionalProperties": false,
      "properties": {
        "projectName":   { "type": "string", "minLength": 1 },
        "platform":      { "type": "string" },
        "schemaVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "lastUpdated":   { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "director":      { "type": "string", "minLength": 1 },
        "description":   { "type": "string" },
        "domain":        { "type": "string" },
        "deploymentTarget": { "type": "string" },
        "stack": {
          "type": "object",
          "properties": {
            "language":  { "type": "string" },
            "framework": { "type": "string" },
            "extras":    { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "role", "modelTier", "file"],
        "additionalProperties": false,
        "properties": {
          "id":          { "type": "string", "minLength": 1 },
          "name":        { "type": "string", "minLength": 1 },
          "role":        { "type": "string", "minLength": 1 },
          "modelTier":   { "type": "string", "enum": ["high-reasoning", "balanced", "fast"] },
          "file":        { "type": "string", "minLength": 1 },
          "matchCategories": {
            "type": "array",
            "items": { "type": "string" }
          },
          "matchKeywords": {
            "type": "array",
            "items": { "type": "string" }
          },
          "contextFiles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "systemPromptFile":        { "type": "string" },
          "requiresDirectorApproval":{ "type": "boolean" },
          "autoApprove":             { "type": "boolean" },
          "persona":       { "type": "string" },
          "command":       { "type": "string" },
          "model":         { "type": "string" },
          "triggerEvents": { "type": "array", "items": { "type": "string" } },
          "matchPriorities":{ "type": "array", "items": { "type": "string" } },
          "capabilities":  { "type": "array", "items": { "type": "string" } },
          "autoActivate":  { "type": "boolean" },
          "systemPrompt":  { "type": "string" },
          "tools":         { "type": "array", "items": { "type": "string" } },
          "mcpTools":      { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "alwaysApply", "file"],
        "additionalProperties": false,
        "properties": {
          "id":            { "type": "string", "minLength": 1 },
          "name":          { "type": "string", "minLength": 1 },
          "alwaysApply":   { "type": "boolean" },
          "file":          { "type": "string", "minLength": 1 },
          "section":       { "type": "string" },
          "triggerKeywords": {
            "type": "array",
            "items": { "type": "string" }
          },
          "ownedBy":     { "type": ["string", "null"] },
          "description": { "type": "string" },
          "content":     { "type": "string" }
        }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "file", "canonicalFile", "ownedBy"],
        "additionalProperties": false,
        "properties": {
          "id":            { "type": "string", "minLength": 1 },
          "name":          { "type": "string", "minLength": 1 },
          "file":          { "type": "string", "minLength": 1 },
          "canonicalFile": { "type": "string", "minLength": 1 },
          "ownedBy":       { "type": "string", "minLength": 1 },
          "triggerKeywords": {
            "type": "array",
            "items": { "type": "string" }
          },
          "description":     { "type": "string" },
          "subFiles":        { "type": "array", "items": { "type": "string" } },
          "skillDependencies":{ "type": "array", "items": { "type": "string" } },
          "skillOutput":     { "type": "string" },
          "skillPipeline":   { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "hooks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "event", "description", "type", "enabled"],
        "additionalProperties": false,
        "properties": {
          "id":                   { "type": "string", "minLength": 1 },
          "event":                { "type": "string", "minLength": 1 },
          "description":          { "type": "string" },
          "activates":            { "type": "string" },
          "type":                 { "type": "string", "enum": ["script", "instruction"] },
          "scriptPath":           { "type": "string" },
          "directorApproval":     { "type": "boolean" },
          "enabled":              { "type": "boolean" },
          "continue":             { "type": "boolean" },
          "suppressOutput":       { "type": "boolean" }
        }
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "additionalProperties": false,
        "properties": {
          "id":          { "type": "string", "minLength": 1 },
          "agentId":     { "type": ["string", "null"] },
          "description": { "type": "string" }
        }
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "when", "activate"],
        "additionalProperties": false,
        "properties": {
          "id":               { "type": "string", "minLength": 1 },
          "when":             { "type": "object" },
          "activate":         { "type": "array", "items": { "type": "string" } },
          "directorApproval": { "type": "boolean" }
        }
      }
    },
    "director": {
      "type": "object",
      "properties": {
        "agentId":   { "type": "string" },
        "overrides": { "type": "object" }
      }
    },
    "joiningPatterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "agents", "flow"],
        "additionalProperties": false,
        "properties": {
          "id":     { "type": "string", "minLength": 1 },
          "file":   { "type": "string", "minLength": 1 },
          "agents": {
            "type": "array",
            "minItems": 2,
            "items": { "type": "string" }
          },
          "flow":   { "type": "string", "enum": ["sequential", "pipeline", "parallel"] }
        }
      }
    }
  }
}
