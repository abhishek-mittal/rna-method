{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/abhishekmittal/rna-method/schema/rna-schema-definition.json",
  "title": "RNA Method Schema",
  "description": "JSON Schema validator for rna-schema.json files. Version 1.0.",
  "type": "object",
  "required": ["meta", "agents", "rules", "skills", "hooks", "joiningPatterns"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["projectName", "platform", "schemaVersion", "lastUpdated", "director"],
      "additionalProperties": false,
      "properties": {
        "projectName":   { "type": "string", "minLength": 1 },
        "platform":      { "type": "string", "enum": ["cursor", "copilot", "claude-code", "codex", "kimi"] },
        "schemaVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "lastUpdated":   { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "director":      { "type": "string", "minLength": 1 }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "role", "modelTier", "file"],
        "additionalProperties": false,
        "properties": {
          "id":          { "type": "string", "minLength": 1 },
          "name":        { "type": "string", "minLength": 1 },
          "role":        { "type": "string", "minLength": 1 },
          "modelTier":   { "type": "string", "enum": ["high-reasoning", "balanced", "fast"] },
          "file":        { "type": "string", "minLength": 1 },
          "matchCategories": {
            "type": "array",
            "items": { "type": "string" }
          },
          "matchKeywords": {
            "type": "array",
            "items": { "type": "string" }
          },
          "contextFiles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "systemPromptFile":        { "type": "string" },
          "requiresDirectorApproval":{ "type": "boolean" },
          "autoApprove":             { "type": "boolean" }
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "alwaysApply", "file"],
        "additionalProperties": false,
        "properties": {
          "id":            { "type": "string", "minLength": 1 },
          "name":          { "type": "string", "minLength": 1 },
          "alwaysApply":   { "type": "boolean" },
          "file":          { "type": "string", "minLength": 1 },
          "section":       { "type": "string" },
          "triggerKeywords": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "file", "canonicalFile", "ownedBy"],
        "additionalProperties": false,
        "properties": {
          "id":            { "type": "string", "minLength": 1 },
          "name":          { "type": "string", "minLength": 1 },
          "file":          { "type": "string", "minLength": 1 },
          "canonicalFile": { "type": "string", "minLength": 1 },
          "ownedBy":       { "type": "string", "minLength": 1 },
          "triggerKeywords": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "hooks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "event", "description", "type", "enabled"],
        "additionalProperties": false,
        "properties": {
          "id":                   { "type": "string", "minLength": 1 },
          "event":                { "type": "string", "minLength": 1 },
          "description":          { "type": "string" },
          "activates":            { "type": "string" },
          "type":                 { "type": "string", "enum": ["script", "instruction"] },
          "scriptPath":           { "type": "string" },
          "directorApproval":     { "type": "boolean" },
          "enabled":              { "type": "boolean" }
        }
      }
    },
    "joiningPatterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "file", "agents", "flow"],
        "additionalProperties": false,
        "properties": {
          "id":     { "type": "string", "minLength": 1 },
          "file":   { "type": "string", "minLength": 1 },
          "agents": {
            "type": "array",
            "minItems": 2,
            "items": { "type": "string" }
          },
          "flow":   { "type": "string", "enum": ["sequential", "pipeline", "parallel"] }
        }
      }
    }
  }
}
